# Copy to .env and fill in. Never commit .env.

# OpenAI API key (LLM + embeddings) — required for drafting
OPENAI_API_KEY=sk-your-key-here

# Anthropic API key (optional, Claude as drafting model)
ANTHROPIC_API_KEY=

# Fernet key for encrypting IMAP passwords / OAuth tokens at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Hard monthly cap on LLM API spend (PLN)
API_COST_HARD_LIMIT_PLN=500
